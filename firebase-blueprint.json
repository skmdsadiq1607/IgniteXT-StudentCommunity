{
  "entities": {
    "Resource": {
      "title": "Academic Resource",
      "description": "A study material like notes or PYQs",
      "type": "object",
      "properties": {
        "department": { "type": "string" },
        "year": { "type": "string" },
        "semester": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "file_url": { "type": "string" },
        "type": { "type": "string", "enum": ["notes", "pyq", "other"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["department", "year", "semester", "subject", "title", "file_url", "type"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "A member of the IgniteXT community team",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "department": { "type": "string" },
        "year": { "type": "string" },
        "role": { "type": "string" },
        "contact": { "type": "string" },
        "email": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "role", "category"]
    },
    "Event": {
      "title": "Event",
      "description": "An upcoming or past event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["upcoming", "past"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "type"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "A message sent via the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "to": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message", "to"]
    }
  },
  "firestore": {
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Academic resources collection"
    },
    "/team/{memberId}": {
      "schema": "TeamMember",
      "description": "Team members collection"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Events collection"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Contact messages collection"
    }
  }
}
