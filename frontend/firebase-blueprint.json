{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Private user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's college email." },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's role in the community." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Resource": {
      "title": "Academic Resource",
      "description": "Notes, projects, and other academic materials.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the resource." },
        "description": { "type": "string", "description": "Brief description of the resource." },
        "category": { "type": "string", "description": "Department or subject category." },
        "year": { "type": "string", "description": "Academic year (e.g., 1st Year)." },
        "link": { "type": "string", "format": "uri", "description": "Link to the resource (e.g., Google Drive)." },
        "authorId": { "type": "string", "description": "UID of the user who shared the resource." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the resource was added." }
      },
      "required": ["title", "link", "category", "year"]
    },
    "Event": {
      "title": "Community Event",
      "description": "Workshops, seminars, and other community activities.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the event." },
        "description": { "type": "string", "description": "Detailed event description." },
        "date": { "type": "string", "format": "date-time", "description": "When the event will take place." },
        "location": { "type": "string", "description": "Where the event will be held." },
        "link": { "type": "string", "format": "uri", "description": "Link for registration or more info." },
        "type": { "type": "string", "enum": ["Workshop", "Seminar", "Hackathon", "Social"], "description": "Type of event." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the event was posted." }
      },
      "required": ["title", "date", "type"]
    },
    "Contact": {
      "title": "Contact Submission",
      "description": "Messages sent through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name." },
        "email": { "type": "string", "format": "email", "description": "Sender's email." },
        "message": { "type": "string", "description": "The message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Academic resources collection."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Community events collection."
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Contact form submissions."
    }
  }
}
